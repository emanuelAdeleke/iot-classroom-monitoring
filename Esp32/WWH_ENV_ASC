#include <Wire.h>
#include <DFRobot_AHT20.h>
#include <DFRobot_ENS160.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <WiFi.h>
#include <PubSubClient.h>

// ==========================
// DEVICE IDENTITY
// ==========================
const char* device_id = "classroom016";
const char* device_name = "Classroom 016 IoT";

// ==========================
// OLED Settings
// ==========================
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET    -1
#define OLED_ADDR     0x3C
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// ==========================
// SENSOR OBJECTS
// ==========================
DFRobot_AHT20 aht20(Wire);
DFRobot_ENS160_I2C ens160(&Wire, 0x53);
const int LIGHT_DO_PIN = 34;

// ==========================
// WIFI & MQTT CONFIG
// ==========================
// iPhone hotspot
const char* ssid = "Emmy";             
const char* password = "Emmanuel412";  

// MQTT Broker → HiveMQ cloud
const char* mqtt_server = "broker.hivemq.com";  
const int mqtt_port = 1883;
const char* mqtt_topic = "WWH/016/env/device-02";

WiFiClient espClient;
PubSubClient client(espClient);

// ==========================
// GLOBALS
// ==========================
float g_tempC = NAN;
float g_humidity = NAN;
uint16_t g_tvoc = 0;
uint16_t g_eco2 = 0;
uint8_t g_aqi = 0;
uint8_t g_status = 0;

unsigned long lastReadMs = 0;
const unsigned long READ_INTERVAL_MS = 5000;

// ==========================
// WIFI SETUP + AUTO-RECONNECT
// ==========================
void setup_wifi() {
  Serial.print("Connecting to WiFi: ");
  Serial.println(ssid);
  WiFi.begin(ssid, password);

  int retry = 0;
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
    retry++;
    if (retry > 20) { // retry 20 times then reset
      Serial.println("\nRestarting WiFi...");
      WiFi.disconnect();
      WiFi.begin(ssid, password);
      retry = 0;
    }
  }

  Serial.println("\nWiFi connected!");
  Serial.print("IP Address: "); Serial.println(WiFi.localIP());
}

// ==========================
// MQTT RECONNECT
// ==========================
void reconnect() {
  while (!client.connected()) {
    Serial.print("Connecting to MQTT...");
    if (client.connect(device_id)) {
      Serial.println("connected!");
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" retrying in 2s...");
      delay(2000);
    }
  }
}

// ==========================
// SETUP
// ==========================
void setup() {
  Serial.begin(115200);
  Wire.begin();
  pinMode(LIGHT_DO_PIN, INPUT);

  // OLED
  if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) {
    Serial.println("OLED failed");
  }
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0, 0);
  display.println("Booting...");
  display.display();

  // Sensors
  while (aht20.begin()) {
    Serial.println("AHT20 failed");
    delay(1000);
  }
  while (NO_ERR != ens160.begin()) {
    Serial.println("ENS160 failed");
    delay(3000);
  }
  ens160.setPWRMode(ENS160_STANDARD_MODE);
  ens160.setTempAndHum(25.0, 50.0);

  setup_wifi();
  client.setServer(mqtt_server, mqtt_port);
}

// ==========================
// LOOP
// ==========================
void loop() {
  // Auto WiFi reconnect
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi lost. Reconnecting...");
    setup_wifi();
  }

  // MQTT reconnect
  if (!client.connected()) reconnect();
  client.loop();

  unsigned long now = millis();
  if (now - lastReadMs >= READ_INTERVAL_MS) {
    lastReadMs = now;

    readAHT20();
    readENS160();

    bool lightBright = digitalRead(LIGHT_DO_PIN) == LOW;

    printToSerial(lightBright);
    printToOLED(lightBright);
    publishToMQTT(lightBright);
  }
}

// ==========================
// SENSOR READS
// ==========================
void readAHT20() {
  if (aht20.startMeasurementReady()) {
    g_tempC = aht20.getTemperature_C();
    g_humidity = aht20.getHumidity_RH();
    ens160.setTempAndHum(g_tempC, g_humidity);
  }
}

void readENS160() {
  g_status = ens160.getENS160Status();
  g_aqi = ens160.getAQI();
  g_tvoc = ens160.getTVOC();
  g_eco2 = ens160.getECO2();
}

// ==========================
// MQTT PUBLISH
// ==========================
void publishToMQTT(bool lightBright) {
  if (isnan(g_tempC) || isnan(g_humidity)) {
    Serial.println("Invalid sensor data, skipping MQTT");
    return;
  }

  String payload = "{";
  payload += "\"device\":\"" + String(device_name) + "\",";
  payload += "\"temp_c\":" + String(g_tempC, 2) + ",";
  payload += "\"rh\":" + String(g_humidity, 2) + ",";
  payload += "\"eco2_ppm\":" + String(g_eco2) + ",";
  payload += "\"tvoc_ppb\":" + String(g_tvoc) + ",";
  payload += "\"aqi\":" + String(g_aqi) + ",";
  payload += "\"light\":" + String(lightBright ? 1 : 0);
  payload += "}";

  client.publish(mqtt_topic, payload.c_str());
  Serial.println("MQTT Sent:");
  Serial.println(payload);
}

// ==========================
// SERIAL OUTPUT
// ==========================
void printToSerial(bool lightBright) {
  Serial.println("---- Sensor ----");
  Serial.print("Device: "); Serial.println(device_name);
  Serial.print("Temp: "); Serial.println(g_tempC);
  Serial.print("RH: "); Serial.println(g_humidity);
  Serial.print("AQI: "); Serial.println(g_aqi);
  Serial.print("TVOC: "); Serial.println(g_tvoc);
  Serial.print("eCO2: "); Serial.println(g_eco2);
  Serial.print("Light: "); Serial.println(lightBright ? "BRIGHT" : "DARK");
  Serial.println();
}

// ==========================
// OLED DISPLAY
// ==========================
void printToOLED(bool lightBright) {
  display.clearDisplay();
  display.setTextSize(1);
  display.setCursor(0, 0);
  display.println(device_name);
  display.setCursor(0, 12);
  display.print("T: "); display.println(isnan(g_tempC) ? "--" : String(g_tempC, 1));
  display.print("RH: "); display.println(isnan(g_humidity) ? "--" : String(g_humidity, 1));
  display.print("AQI: "); display.println(g_aqi);
  display.print("TVOC: "); display.println(g_tvoc);
  display.print("eCO2: "); display.println(g_eco2);
  display.print("Light: "); display.println(lightBright ? "Bright" : "Dark");
  display.display();
}
